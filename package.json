{
  "name": "framerate",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:landing\" \"bun run dev:app\" \"bun run dev:backend\"",
    "dev:app": "cd apps/app && bun run dev",
    "dev:backend": "cd apps/backend && go run .",
    "dev:landing": "cd apps/landing && bun run dev"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
